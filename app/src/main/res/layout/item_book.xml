<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="250dp"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:strokeWidth="1dp"
    app:strokeColor="?attr/colorOutlineVariant">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/colorSurfaceVariant">

        <!-- Cover Design: Spine/Binding lines at the left edge to simulate a book binding -->
        <View
            android:id="@+id/book_spine"
            android:layout_width="8dp"
            android:layout_height="match_parent"
            android:background="?attr/colorPrimary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <View
            android:id="@+id/book_spine_shadow"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="#20000000"
            app:layout_constraintStart_toEndOf="@id/book_spine"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Title of the Book inside the cover -->
        <TextView
            android:id="@+id/tv_book_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="28dp"
            android:text="Fathul Mu'in"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:maxLines="3"
            android:ellipsize="end"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/book_spine_shadow"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Author name -->
        <TextView
            android:id="@+id/tv_book_author"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:text="Zainuddin Al-Malibari"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:alpha="0.8"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="end"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/book_spine_shadow"
            app:layout_constraintTop_toBottomOf="@id/tv_book_title" />

        <!-- Thin horizontal separator line on the cover -->
        <View
            android:id="@+id/cover_line"
            android:layout_width="60dp"
            android:layout_height="1dp"
            android:background="?attr/colorPrimary"
            android:layout_marginTop="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/book_spine_shadow"
            app:layout_constraintTop_toBottomOf="@id/tv_book_author" />

        <!-- Badge showing indexing status -->
        <TextView
            android:id="@+id/tv_indexing_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_badge_indexed"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="Indeks Aktif"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/tv_book_stats"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/book_spine_shadow" />

        <!-- Book Stats (e.g. pages) at the very bottom -->
        <TextView
            android:id="@+id/tv_book_stats"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="16dp"
            android:text="674 Halaman"
            android:textSize="11sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:alpha="0.7"
            android:gravity="center"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/book_spine_shadow" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
